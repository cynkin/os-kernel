ENTRY(_start)

SECTIONS {
    . = 1M;

    /* Multiboot header MUST be first so GRUB finds it */
    .multiboot : {
        *(.multiboot)
    }

    .text : {
        *(.text)
    }

    .rodata : {
        *(.rodata)
    }

    .data : {
        *(.data)
    }

    .bss : {
        *(COMMON)
        *(.bss)
    }
}